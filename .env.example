# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10

# JWT (mobile app)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App Panel (admin — separate from mobile JWT)
PANEL_API_ENABLED=true
PANEL_API_KEY=change-me-long-random-secret
PANEL_TIMEZONE=Europe/Istanbul
PANEL_DAILY_DAYS=30
# PANEL_ALLOWED_IPS=1.2.3.4,5.6.7.8
PANEL_VIDEO_MAX_MB=150
PANEL_IMAGE_MAX_MB=10

# Bunny CDN (profile photos)
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_ZONE_PASSWORD=
BUNNY_STORAGE_PATH=
